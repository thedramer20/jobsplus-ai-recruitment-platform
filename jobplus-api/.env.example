# JobPlus API — environment template
# Copy to `.env` and fill in real values. Never commit the real `.env`.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=jobplus-api
SERVER_PORT=8080

# ── Database (MySQL 8) ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jobplus
DB_USERNAME=root
DB_PASSWORD=change-me

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Use long random strings (>= 32 chars). Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_REFRESH_EXPIRY_MS=604800000

# Minutes a password-reset link stays valid
PASSWORD_RESET_EXPIRY_MINUTES=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_SQL=INFO

# ── AI / Chatbot ──────────────────────────────────────────────────────────────
# AI_PROVIDER: none | groq | openai. Leave key blank to disable the chatbot.
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=llama-3.1-8b-instant

# ── CORS / Frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── File storage (avatars, resumes) ───────────────────────────────────────────
# UPLOAD_BASE_URL host:port must match SERVER_PORT so served /uploads URLs resolve.
UPLOAD_LOCAL_PATH=./uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
# Set MAIL_ENABLED=true and provide SMTP credentials to send real emails.
# When false, emails are logged and skipped (safe for local dev).
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@jobplus.com
